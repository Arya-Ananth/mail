# Gmail Credentials
# Create an App Password in your Google Account:
# 1. Go to your Google Account (myaccount.google.com)
# 2. Go to Security -> 2-Step Verification
# 3. Scroll to the bottom and select 'App passwords' (if not visible, search for it)
# 4. Generate a password for 'Mail' / 'Other' and copy the 16-character code
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Scan Settings
SCAN_DAYS_LIMIT=30
SCAN_MAX_EMAILS=200

# Custom Keywords (Comma-separated)
INCLUDE_KEYWORDS=next round,interview,schedule,shortlisted,selected,technical test,assessment,move forward,moving forward,next steps,phone screen,technical screen,coding test,coding challenge,invitation to
EXCLUDE_KEYWORDS=unfortunately,not moving forward,thank you for your time,not selected,decided to go with,regret to inform,we will not be moving,rejected,reject,unable to offer,interview prep,interview preparation,interview tips,mock interview,practice interview,interview questions,digest,newsletter,weekly review,daily review,job recommendation,job alert,jobs for you,new jobs,suggested jobs,weekly update,weekly challenge,weekly contest,contest results,someone viewed,connection request,verification code,reset password,security alert,sign-in attempt


